rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny for safety
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow public access to our specific ecocycle_data collection and documents
    match /ecocycle_data/{document} {
      allow read, write: if true;
    }
  }
}
